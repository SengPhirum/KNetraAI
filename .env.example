POSTGRES_DB=vision_ai
POSTGRES_USER=vision
POSTGRES_PASSWORD=vision
DATABASE_URL=postgresql://vision:vision@postgres:5432/vision_ai
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-this-jwt-secret
INTERNAL_API_KEY=change-this-internal-key
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=System Admin

AI_SERVICE_URL=http://ai-service:8001
BACKEND_URL=http://backend:8000
STORAGE_DIR=/data
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

AI_PROVIDER=opencv_mock
PROCESS_FPS=2
RECOGNITION_THRESHOLD=0.45
GREETING_COOLDOWN_SECONDS=300
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Public URLs used for OIDC redirects (must match what the browser uses).
FRONTEND_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# --- OIDC single sign-on (Keycloak, Authentik, or any OpenID Connect provider) ---
# Preferred: configure via Settings -> Authentication in the app (applies instantly,
# includes Keycloak/Authentik guides). Values below act as initial defaults only;
# anything saved in the UI overrides them.
OIDC_ENABLED=false
OIDC_ISSUER=
# Keycloak example:  https://keycloak.example.com/realms/master
# Authentik example: https://authentik.example.com/application/o/knetraai/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email
OIDC_PROVIDER_NAME=SSO
OIDC_DEFAULT_ROLE=Viewer
OIDC_AUTO_CREATE_USERS=true

# --- LDAP / Active Directory ---
LDAP_ENABLED=false
LDAP_SERVER_URL=
# e.g. ldap://ad.example.com:389 or ldaps://ad.example.com:636
# Option A - direct bind template:
LDAP_USER_DN_TEMPLATE=
# e.g. uid={username},ou=users,dc=example,dc=org
# Option B - service-account search then bind:
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_SEARCH_BASE=
# e.g. ou=users,dc=example,dc=org
LDAP_USER_FILTER=(|(uid={username})(sAMAccountName={username})(mail={username}))
LDAP_EMAIL_ATTRIBUTE=mail
LDAP_NAME_ATTRIBUTE=cn
LDAP_DEFAULT_ROLE=Viewer
