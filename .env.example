POSTGRES_DB=vision_ai
POSTGRES_USER=vision
POSTGRES_PASSWORD=vision
DATABASE_URL=postgresql://vision:vision@postgres:5432/vision_ai
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-this-jwt-secret
INTERNAL_API_KEY=change-this-internal-key
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=System Admin

AI_SERVICE_URL=http://ai-service:8001
# Internal, container-to-container address. Used by ai-service to reach the backend,
# and by the frontend's own Nitro server to proxy /api/** - the browser never calls
# this URL directly, so it never needs to be a host-reachable address.
BACKEND_URL=http://backend:8000
STORAGE_DIR=/data
# Host-side port the backend is published on (container always listens on 8000
# internally). Not needed by the app itself (the browser only ever talks to the
# frontend, which proxies to the backend server-side) - this just keeps
# http://localhost:8010/docs reachable for direct API debugging.
BACKEND_HOST_PORT=8010
# Not used by the app's own traffic (frontend->backend is same-origin via the Nitro
# proxy now, so no CORS preflight is involved). Only matters if something else calls
# the backend's published port directly from a browser.
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

AI_PROVIDER=yolo_cascade
PROCESS_FPS=2
RECOGNITION_THRESHOLD=0.45
GREETING_COOLDOWN_SECONDS=300

# --- Device profile (performance auto-tuning) ---
# "auto" detects Raspberry-Pi-class ARM boards / low-core hosts at startup and lowers
# model input sizes, ONNX Runtime thread counts, and target FPS to defaults that stay
# smooth on them - see the "Running on a Raspberry Pi" section in README.md. Only
# applies to the settings below that you leave at their documented default value here;
# anything you've deliberately changed is always left alone. Force a tier explicitly
# (low/balanced/high) to skip auto-detection, e.g. for a board detection gets wrong.
DEVICE_PROFILE=auto
# 0 = let ONNX Runtime pick its own thread count (fine on a desktop/server). Set to a
# small number on a multi-core SBC so one camera's inference doesn't claim every core -
# device_profile=low/balanced already do this for you.
ONNX_INTRA_OP_THREADS=0
ONNX_INTER_OP_THREADS=0
# Caps how many cameras may run AI inference at the same instant (0 = unlimited). On a
# single-board computer, several cameras all inferring at once thrashes the CPU far
# worse than queuing them - device_profile=low/balanced set this for you.
MAX_CONCURRENT_INFERENCE=0
# If a camera can't keep up with PROCESS_FPS, back its target rate off to whatever it
# can actually sustain instead of continuously falling behind.
ADAPTIVE_FRAME_SKIP=true

# --- Face detection quality ---
# yolo_cascade (recommended): fast YOLO12 person detection narrows the frame down to
#   person crops before the accurate InsightFace (SCRFD+ArcFace) stage runs on them -
#   faster and better small/far-face recall than scanning the whole frame. Falls back
#   to plain "insightface" automatically if the YOLO ONNX model isn't present (e.g.
#   image built without the export stage).
# insightface: accurate deep-learning face detector/embeddings without the YOLO stage.
# opencv_mock: no ML models, UI/API development only.
ALLOW_PROVIDER_FALLBACK=false
FACE_MIN_CONFIDENCE=0.50
FACE_MIN_AREA_RATIO=0.0002
FACE_MAX_AREA_RATIO=0.35
FACE_MAX_DETECTIONS=12
GENDER_MIN_CONFIDENCE=0.60
# buffalo_l: full-accuracy pack. buffalo_s: InsightFace's small pack (lighter SCRFD
# detector + smaller recognition backbone) - much cheaper per frame, used automatically
# by DEVICE_PROFILE=low. Both download automatically the same way on first use.
INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_MODEL_ROOT=/data/insightface
INSIGHTFACE_DET_SIZE=960
# "auto" picks the fastest available ONNX Runtime execution provider (CUDA/TensorRT/
# CoreML/DirectML if present, else CPU). Set explicitly (e.g. CPUExecutionProvider) to force it.
INSIGHTFACE_PROVIDERS=auto
ORT_LOG_SEVERITY_LEVEL=3
# -2 = derive from INSIGHTFACE_PROVIDERS (GPU provider chosen -> 0, else -1 for CPU).
INSIGHTFACE_CTX_ID=-2
INSIGHTFACE_ENABLE_TILED_DETECTION=true
INSIGHTFACE_TILE_MIN_WIDTH=1100
INSIGHTFACE_TILE_OVERLAP=0.18
# Set true only when Docker is behind a local/corporate TLS proxy with self-signed certificates.
INSIGHTFACE_INSECURE_MODEL_DOWNLOAD=false

# --- YOLO person-detection cascade (used when AI_PROVIDER=yolo_cascade) ---
# The Docker build also produces yolo12n-int8.onnx (dynamically quantized, ~1/3 the
# size, noticeably faster on CPUs without AVX512/VNNI - i.e. essentially any ARM SBC).
# DEVICE_PROFILE=low points here automatically; set it explicitly to try it elsewhere.
YOLO_PERSON_MODEL_PATH=/app/models/yolo12n.onnx
YOLO_INPUT_SIZE=640
YOLO_PROVIDERS=auto
YOLO_PERSON_CONF=0.35
YOLO_NMS_THRESHOLD=0.45
# Ignore person boxes shorter than this fraction of the frame height (too small/far to crop usefully).
YOLO_PERSON_MIN_HEIGHT_RATIO=0.10
YOLO_CROP_PADDING=0.25
YOLO_MAX_PERSONS=8
# Safety net for close-up cameras (e.g. a greeting kiosk) where a face fills the frame
# but little/no body is visible for YOLO to key off: run one full-frame InsightFace
# pass whenever the person-crop pass finds zero faces.
YOLO_FALLBACK_FULL_FRAME=true
# Show a "person detected, not yet recognized" overlay for person boxes with no face
# found inside them (e.g. back turned to camera).
YOLO_EMIT_PERSON_ONLY_DETECTIONS=true
YOLO_FACE_DET_SIZE=640

# --- Motion-gated inference ---
# Skip the (comparatively expensive) AI pass on frames with no meaningful change from
# the last processed one, except for a periodic idle poll - cuts average CPU/GPU load
# on typical CCTV scenes that are empty most of the time, without adding detection lag.
MOTION_GATING_ENABLED=true
MOTION_GATING_MIN_AREA_RATIO=0.004
MOTION_GATING_IDLE_INTERVAL_SECONDS=2.0

OPENCV_FACE_SCALE_FACTOR=1.08
OPENCV_FACE_MIN_NEIGHBORS=7
OPENCV_FACE_MIN_SIZE=44
OPENCV_REQUIRE_EYE_VALIDATION=true
OPENCV_MIN_EYES=1
OPENCV_ENABLE_MOCK_GENDER=false
OPENCV_ENABLE_PERSON_DETECTOR=false
OPENCV_PERSON_HIT_THRESHOLD=0.0
OPENCV_PERSON_MIN_HEIGHT=80

# --- Live view (MJPEG) and ONVIF camera discovery ---
STREAM_JPEG_QUALITY=80
STREAM_MAX_WIDTH=960
ONVIF_DISCOVERY_TIMEOUT=4.0
ONVIF_PROBE_TIMEOUT=8.0
# Channel preview thumbnail (captured from the same test frame used to validate a channel
# during "Fetch Channels", so it costs no extra RTSP connection). 0 disables downscaling.
ONVIF_THUMBNAIL_MAX_WIDTH=320
ONVIF_THUMBNAIL_JPEG_QUALITY=70

# Public URLs used for OIDC redirects (must match what the browser uses).
FRONTEND_BASE_URL=http://localhost:3010
API_BASE_URL=http://localhost:8010

# --- OIDC single sign-on (Keycloak, Authentik, or any OpenID Connect provider) ---
# Preferred: configure via Settings -> Authentication in the app (applies instantly,
# includes Keycloak/Authentik guides). Values below act as initial defaults only;
# anything saved in the UI overrides them.
OIDC_ENABLED=false
OIDC_ISSUER=
# Keycloak example:  https://keycloak.example.com/realms/master
# Authentik example: https://authentik.example.com/application/o/knetraai/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email
OIDC_PROVIDER_NAME=SSO
OIDC_DEFAULT_ROLE=Viewer
OIDC_AUTO_CREATE_USERS=true

# --- LDAP / Active Directory ---
LDAP_ENABLED=false
LDAP_SERVER_URL=
# e.g. ldap://ad.example.com:389 or ldaps://ad.example.com:636
# Option A - direct bind template:
LDAP_USER_DN_TEMPLATE=
# e.g. uid={username},ou=users,dc=example,dc=org
# Option B - service-account search then bind:
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_SEARCH_BASE=
# e.g. ou=users,dc=example,dc=org
LDAP_USER_FILTER=(|(uid={username})(sAMAccountName={username})(mail={username}))
LDAP_EMAIL_ATTRIBUTE=mail
LDAP_NAME_ATTRIBUTE=cn
LDAP_DEFAULT_ROLE=Viewer
