# Copy to docker/.env.production, change all secrets, then deploy with:
# docker compose --env-file docker/.env.production -f docker/docker-compose.yml up -d --build

ENVIRONMENT=production
TZ=Asia/Phnom_Penh
KNETRAAI_TAG=latest
HTTP_PORT=80

POSTGRES_DB=vision_ai
POSTGRES_USER=vision
POSTGRES_PASSWORD=change-this-postgres-password

JWT_SECRET=change-this-long-random-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=720
INTERNAL_API_KEY=change-this-long-random-internal-key

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
DEFAULT_ADMIN_NAME=System Admin

# Same-origin deployment through nginx: browser requests go to http://your-domain/api,
# which nginx.conf routes straight to the backend container - the frontend's own build
# always requests same-origin /api regardless, nothing to configure here.
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://your-domain.com,https://your-domain.com

# yolo_cascade (recommended): fast YOLO12 person detection narrows the frame down to
# person crops before the accurate InsightFace stage runs on them. Falls back to plain
# insightface automatically if the YOLO ONNX model isn't present. Use opencv_mock only
# for UI/API development.
AI_PROVIDER=yolo_cascade
PROCESS_FPS=2
RECOGNITION_THRESHOLD=0.45
GREETING_COOLDOWN_SECONDS=300
FACE_MIN_CONFIDENCE=0.50
FACE_MIN_AREA_RATIO=0.0002
FACE_MAX_AREA_RATIO=0.35
FACE_MAX_DETECTIONS=12
GENDER_MIN_CONFIDENCE=0.60
SNAPSHOT_JPEG_QUALITY=85
INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_MODEL_ROOT=/data/insightface
INSIGHTFACE_DET_SIZE=960
INSIGHTFACE_PROVIDERS=CPUExecutionProvider
ORT_LOG_SEVERITY_LEVEL=3
INSIGHTFACE_CTX_ID=-1
INSIGHTFACE_ENABLE_TILED_DETECTION=true
INSIGHTFACE_TILE_MIN_WIDTH=1100
INSIGHTFACE_TILE_OVERLAP=0.18
# Keep false in production. Use a trusted CA bundle instead of disabling TLS verification.
INSIGHTFACE_INSECURE_MODEL_DOWNLOAD=false
ALLOW_PROVIDER_FALLBACK=false
OPENCV_ENABLE_PERSON_DETECTOR=false

# Live view (MJPEG) and ONVIF camera discovery
STREAM_JPEG_QUALITY=80
STREAM_MAX_WIDTH=960
ONVIF_DISCOVERY_TIMEOUT=4.0
ONVIF_PROBE_TIMEOUT=8.0
